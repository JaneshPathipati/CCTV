# Migration Environment Variables
# Copy this file to .env.local and fill in your credentials

# ============================================
# OLD SUPABASE PROJECT (Source)
# ============================================
OLD_SUPABASE_URL=https://your-old-project.supabase.co
OLD_SUPABASE_KEY=your_old_service_role_key

# ============================================
# NEW SUPABASE PROJECT (Destination)
# ============================================
NEW_SUPABASE_URL=https://your-new-project.supabase.co
NEW_SUPABASE_KEY=your_new_service_role_key

# ============================================
# CURRENT PROJECT (for export)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-current-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_current_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_current_service_role_key

# ============================================
# NOTES:
# ============================================
# 1. Get these values from Supabase Dashboard → Settings → API
# 2. Service role key is SECRET - never commit to Git
# 3. For export: Use current project credentials
# 4. For import: Add NEW_ prefixed credentials
# 5. For image migration: Need both OLD_ and NEW_ credentials
